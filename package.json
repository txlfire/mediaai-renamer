{
  "name": "mediaai-renamer",
  "version": "0.10.5",
  "private": true,
  "type": "module",
  "scripts": {
    "frontend:dev": "powershell -ExecutionPolicy Bypass -File scripts/start-frontend-dev.ps1 -HostName 127.0.0.1 -Port 5173",
    "frontend:dev:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-frontend-dev.ps1 -HostName 0.0.0.0 -Port 5173",
    "dev:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-lan.ps1",
    "dev:start": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-lan.ps1",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev-lan.ps1",
    "dev:windows": "powershell -ExecutionPolicy Bypass -File scripts/dev-windows.ps1",
    "dev:linux": "bash scripts/dev-linux.sh",
    "dev:docker": "bash scripts/dev-docker.sh",
    "dev:start:linux": "bash scripts/start-dev-lan.sh",
    "dev:stop:linux": "bash scripts/stop-dev-lan.sh",
    "backend:dev:lan": "powershell -ExecutionPolicy Bypass -Command \"$env:PYTHONPATH='backend'; .\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port 8970 --reload --app-dir backend\"",
    "frontend:build": "vue-tsc --noEmit --project frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "frontend:test": "vitest run src",
    "backend:test": "powershell -ExecutionPolicy Bypass -File scripts/run-backend-tests.ps1",
    "check:encoding": "powershell -ExecutionPolicy Bypass -File scripts/check-encoding.ps1",
    "backend:test:linux": "bash scripts/run-backend-tests.sh",
    "release:package": "powershell -ExecutionPolicy Bypass -File scripts/package-release.ps1",
    "release:package:linux": "bash scripts/package-release.sh",
    "release:publish": "powershell -ExecutionPolicy Bypass -File scripts/package-release.ps1 -Publish",
    "release:publish:linux": "bash scripts/package-release.sh --publish"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.18.1",
    "element-plus": "^2.8.8",
    "pinia": "^2.2.6",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
